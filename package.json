{
  "name": "clawforge",
  "version": "1.0.0",
  "description": "A local MCP toolkit that extends Claude Code with browser control, persistent vector memory, web search, sub-agents, slash commands, hooks, a component marketplace, and more.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "clawforge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "claude",
    "toolkit",
    "browser",
    "memory"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "glob": "^11.0.1",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "node-cron": "^3.0.3",
    "ollama": "^0.5.12",
    "playwright": "^1.49.0",
    "sqlite-vec": "^0.1.6",
    "undici": "^7.3.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
